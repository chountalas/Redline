REDLINE_LLM_PROVIDER=codex

# Uses your local Codex CLI login/subscription. Optional overrides:
# REDLINE_MODEL=
# REDLINE_CODEX_COMMAND=/opt/homebrew/bin/codex

# API alternative:
# REDLINE_LLM_PROVIDER=openai
# OPENAI_API_KEY=
# REDLINE_MODEL=<openai-model>

# Local alternative (no API key, fully offline):
# REDLINE_LLM_PROVIDER=ollama
# REDLINE_MODEL=gpt-oss:20b
# REDLINE_BASE_URL=http://localhost:11434
# Larger local models are slow; raise the request timeout (seconds):
# REDLINE_OLLAMA_TIMEOUT=600
# Output mode: "json" (default, fast, recommended) binds Ollama's lightweight
# JSON mode; "schema" binds the full JSON-schema grammar (stricter but local
# models often run away on it and never finish). Reasoning is auto-disabled.
# REDLINE_OLLAMA_FORMAT=json

# Optional explicit Anthropic provider:
# REDLINE_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# REDLINE_MODEL=<anthropic-model>
